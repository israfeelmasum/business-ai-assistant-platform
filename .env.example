# ============================================================
# Business AI Assistant Platform — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ── Database (PostgreSQL with pgvector extension) ────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/ai_chatbot_db

# ── Ollama (self-hosted LLM server) ─────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.2:latest

# ── Optional: OpenAI / Google Gemini ────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=AIza...

# ── Application ─────────────────────────────────────────────────────────────
APP_NAME=Business AI Assistant
APP_VERSION=2.0.0
DEBUG=false
SECRET_KEY=replace-this-with-a-long-random-secret-string-min-32-chars

# ── Embedding ───────────────────────────────────────────────────────────────
EMBEDDING_DIMENSION=768

# ── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:9000,https://yourdomain.com

# ── Email (SMTP) ────────────────────────────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
AUTHORITY_EMAIL=admin@yourdomain.com
